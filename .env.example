# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://neonllm:neonllm_dev@localhost:5432/neonllm?schema=public"
REDIS_URL="redis://localhost:6379"

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-to-random-64-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Upstream API keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ─── Payments: Lolzteam Market ──────────────────────────────────────────────
LZT_TOKEN=

# ─── Payments: Cryptomus ────────────────────────────────────────────────────
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# ─── Payments: YooKassa (SBP) ──────────────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ─── Telegram ────────────────────────────────────────────────────────────────
TG_BOT_TOKEN=
TG_ADMIN_CHAT_ID=
NEXT_PUBLIC_TG_CHANNEL="https://t.me/yourchannel"

# ─── Dev ─────────────────────────────────────────────────────────────────────
MOCK_PAYMENTS=true
SEED_ADMIN_EMAIL="admin@neonllm.dev"
SEED_ADMIN_PASSWORD="admin123"